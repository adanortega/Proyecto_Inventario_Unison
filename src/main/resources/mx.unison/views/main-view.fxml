<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="mx.unison.controllers.InventarioController" style="-fx-background-color: #1e1e2e;">
    <left>
        <VBox spacing="15" style="-fx-background-color: #181825; -fx-padding: 20; -fx-min-width: 200;">
            <Label text="INVENTARIO PRO" style="-fx-text-fill: #89b4fa; -fx-font-weight: bold; -fx-font-size: 18;"/>
            <Separator style="-fx-opacity: 0.2;"/>
            <Button text="📦 Productos" onAction="#handleVerProductos" maxWidth="Infinity" style="-fx-cursor: hand;"/>
            <Button text="🏠 Almacenes" onAction="#handleVerAlmacenes" maxWidth="Infinity" style="-fx-cursor: hand;"/>
            <Region VBox.vgrow="ALWAYS" />
            <Button text="🚪 Cerrar Sesión" onAction="#handleLogout" maxWidth="Infinity" style="-fx-background-color: #f38ba8; -fx-text-fill: #1e1e2e; -fx-font-weight: bold;"/>
        </VBox>
    </left>
    <center>
        <VBox spacing="20" style="-fx-padding: 30;">
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label text="Gestión de Datos" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="10">
                    <Button text="➕ Nuevo" onAction="#handleNuevo" style="-fx-background-color: #a6e3a1; -fx-text-fill: #1e1e2e;"/>
                    <Button text="✏️ Editar" onAction="#handleEditar" style="-fx-background-color: #f9e2af; -fx-text-fill: #1e1e2e;"/>
                    <Button text="🗑 Eliminar" onAction="#handleEliminar" style="-fx-background-color: #f38ba8; -fx-text-fill: #1e1e2e;"/>
                </HBox>
            </HBox>
            <TableView fx:id="tablaGeneral" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50" />
                    <TableColumn fx:id="col1" text="Nombre" prefWidth="200" />
                    <TableColumn fx:id="col2" text="Información" prefWidth="120" />
                    <TableColumn fx:id="col3" text="Precio" prefWidth="100" />
                    <TableColumn fx:id="colAlmacen" text="Almacén" prefWidth="150" />
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
            </TableView>
        </VBox>
    </center>
</BorderPane>